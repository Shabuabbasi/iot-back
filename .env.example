# .env Configuration Template

# ===== SERVER CONFIGURATION =====
# Port where the backend server will run
PORT=5000

# ===== DATABASE CONFIGURATION =====
# MongoDB connection string from MongoDB Atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# 
# Steps to get your connection string:
# 1. Go to mongodb.com/cloud/atlas
# 2. Create a cluster
# 3. Click "Connect" → "Connect your application"
# 4. Copy the connection string
# 5. Replace <username> and <password> with your credentials
#
# Example: mongodb+srv://admin:mypassword123@cluster0.abc123.mongodb.net/waste-management
MONGODB_URI=mongodb+srv://username:password@your-cluster-name.mongodb.net/waste-management

# ===== JWT SECRETS =====
# Secret key for JWT token signing
# IMPORTANT: Change this in production! Use strong, random string
# Generate with: openssl rand -base64 32
JWT_SECRET=your_super_secret_key_change_this_in_production

# JWT expiration time
# Options: "7d" (7 days), "24h" (24 hours), "1w" (1 week), etc.
JWT_EXPIRES_IN=7d

# ===== API CONFIGURATION =====
# API base URL (used in frontend/documentation)
API_BASE_URL=http://localhost:5000/api

# ===== ENVIRONMENT TYPE =====
# Options: development, production, testing
NODE_ENV=development

# ===== CORS CONFIGURATION =====
# Allow requests from these origins
# Separate multiple with commas
# Examples: http://localhost:3000,http://localhost:8080
CORS_ORIGIN=*

# ===== IMAGE UPLOAD CONFIGURATION =====
# Maximum file size for images (in bytes)
# Current: 5MB
MAX_FILE_SIZE=5242880

# Upload directory path
UPLOAD_DIR=./uploads

# ===== LOGGING CONFIGURATION =====
# Log level: info, warn, error, debug
LOG_LEVEL=debug

# ===== SMTP CONFIGURATION (Optional - for notifications) =====
# Email service for sending notifications when bins are full
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email to send notifications to
NOTIFICATION_EMAIL=admin@example.com

# ===== SENSOR CONFIGURATION =====
# Distance at which bin is considered full (in cm)
# Used to calculate waste level percentage
MAX_BIN_HEIGHT=30

# Minimum distance reading (safety threshold)
MIN_DISTANCE=2

# Maximum distance reading
MAX_DISTANCE=400

# ===== DEVICE CONFIGURATION =====
# Default send interval for ESP32 (in seconds)
DEVICE_UPDATE_INTERVAL=30

# WiFi configuration backup
WIFI_SSID=Infinix Note 10
WIFI_PASSWORD=abbasi123456

# ===== API RATE LIMITING =====
# Requests per minute per IP
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ===== CACHE CONFIGURATION =====
# Cache statistics for performance
CACHE_STATISTICS=true
CACHE_TTL=300

# ===== SECURITY =====
# Enable HTTPS (requires certificates)
ENABLE_HTTPS=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# ===== NOTES =====
# 
# IMPORTANT SECURITY NOTES:
# 1. Never commit this file to git with real values
# 2. Add .env to .gitignore
# 3. Rotate JWT_SECRET periodically
# 4. Use strong MongoDB password
# 5. In production, use environment variables from cloud provider
# 
# For production deployment:
# - Change NODE_ENV to "production"
# - Use strong JWT_SECRET (32+ characters)
# - Enable HTTPS
# - Restrict CORS_ORIGIN to specific domains
# - Use separate database for production
# - Implement rate limiting
# - Enable logging to file
#
